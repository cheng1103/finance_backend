# Environment Configuration Example
NODE_ENV=production
PORT=3001

# Database Connection (NEVER commit real credentials!)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Domain Configuration
FRONTEND_URL=https://www.eplatformcredit.com
ADMIN_URL=https://admin.eplatformcredit.com

# JWT Configuration (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))")
JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# Admin Credentials
ADMIN_USERNAME=admin
# Generate password hash with: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('YourPassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH=your-bcrypt-password-hash-here

# Security Configuration
CORS_ORIGIN=https://www.eplatformcredit.com,https://admin.eplatformcredit.com,https://eplatformcredit.com
