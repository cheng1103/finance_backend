# ============================================
# SEO Automation System - Environment Variables
# ============================================

# Google Gemini API Configuration (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# WordPress Configuration (REQUIRED for publishing)
WP_API_URL=https://eplatformcredit.com/wp-json/wp/v2/posts
WP_USER=your_wordpress_username
WP_APP_PASSWORD=your_wordpress_application_password
WP_STATUS=publish
WP_AUTHOR_ID=1
WP_CATEGORIES=
WP_TAGS=

# Google Indexing API Configuration (OPTIONAL but recommended)
# Get credentials from Google Cloud Console
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-project-id

# Site Configuration
SITE_URL=https://eplatformcredit.com

# Scheduler Configuration
ARTICLES_PER_DAY=3
CRON_SCHEDULE=0 9 * * *
DELAY_BETWEEN_ARTICLES=30000
SCHEDULER_ENABLED=true

# Article Generation Settings
MIN_WORDS=800
MAX_WORDS=1200
LANGUAGE=English
LOCALE=Malaysia
INCLUDE_FAQ=true
INCLUDE_CTA=true
CTA_TEXT=Contact us via WhatsApp for fast approval!
CTA_LINK=https://wa.me/60123456789

# Logging
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=true
